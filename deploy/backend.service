[Unit]
Description=Centro Comando Agentes IA Backend
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/centro-comando-agentes-ia/backend
EnvironmentFile=/home/ubuntu/centro-comando-agentes-ia/backend/.env
ExecStart=/usr/bin/node /home/ubuntu/centro-comando-agentes-ia/backend/dist/server.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
